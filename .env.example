# Core
APP_NAME=us-equities-forecast
ENVIRONMENT=local
DATABASE_URL=sqlite:///./data/forecast.db
ARTIFACTS_DIR=./artifacts
PROMPTS_DIR=./prompts

# Defaults
FORECAST_HORIZON=5 trading days
MARKET_UNIVERSE=["SPY","QQQ","IWM","VIX","US10Y","DXY","OIL"]
USE_LIVE_DATA=false
ENFORCE_INPUT_FRESHNESS=true
MAX_NEWS_AGE_HOURS=72
MAX_MARKET_AGE_MINUTES=60
ALLOW_LATEST_AVAILABLE_FALLBACK=true
LATEST_AVAILABLE_MAX_NEWS_AGE_HOURS=168
LATEST_AVAILABLE_MAX_MARKET_AGE_MINUTES=10080
MOCK_NEWS_FILE=./data/mock/news_latest.json
MOCK_MARKET_FILE=./data/mock/market_latest.json
LATEST_NEWS_CACHE_FILE=./data/cache/news_latest_available.json
LATEST_MARKET_CACHE_FILE=./data/cache/market_latest_available.json

# LLM
# Supported providers: mock | openai | kimi | minimax
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=45

# CLI output
# OUTPUT_STYLE options: simple | telegram | full
OUTPUT_LANGUAGE=zh
OUTPUT_STYLE=simple

# MiniMax Token Plan example (OpenAI-compatible)
# LLM_PROVIDER=minimax
# LLM_BASE_URL=https://api.minimax.io/v1
# LLM_API_KEY=YOUR_MINIMAX_TOKEN_PLAN_KEY
# LLM_MODEL=MiniMax-M2.5
# LLM_TEMPERATURE=1.0

# Financial Modeling Prep (FMP) for live market indicators
# Docs: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/stable

# News API (recommended for current collector implementation)
# Docs: https://newsapi.org/docs/endpoints/everything
NEWS_API_KEY=
NEWS_API_URL=https://newsapi.org/v2/everything
